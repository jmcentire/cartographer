  "functions": [
    {
      "name": "score_pct",
      "description": "Calculates the percentage of passing checks in a compatibility report. Returns 100.0 if no checks exist (total == 0), otherwise computes (score_pass / total * 100) rounded to 1 decimal place.",
      "inputs": [
        {
          "name": "self",
          "type_ref": "CompatibilityReport",
          "required": true,
          "default": "",
          "description": "The CompatibilityReport instance containing score_pass and total fields",
          "validators": []
        }
      ],
      "output_type": "float",
      "error_cases": [],
      "preconditions": [
        "self.total >= 0",
        "self.score_pass >= 0"
      ],
      "postconditions": [
        "0.0 <= return_value <= 100.0",
        "return_value rounded to 1 decimal place"
      ],
      "idempotent": true,
      "side_effects": [],
      "structured_side_effects": [
        {
          "kind": "none",
          "target": "",
          "description": ""
        }
      ],
      "performance_budget": {
        "p95_latency_ms": 1,
        "max_memory_mb": 1,
        "complexity": "O(1)"
      }
    },
    {
      "name": "has_failures",
      "description": "Checks whether the compatibility report contains any failures. Returns true if score_fail is greater than 0, false otherwise.",
      "inputs": [
        {
          "name": "self",
          "type_ref": "CompatibilityReport",
          "required": true,
          "default": "",
          "description": "The CompatibilityReport instance containing score_fail field",
          "validators": []
        }
      ],
      "output_type": "bool",
      "error_cases": [],
      "preconditions": [
        "self.score_fail >= 0"
      ],
      "postconditions": [
        "return_value == true if self.score_fail > 0 else false"
      ],
      "idempotent": true,
      "side_effects": [],
      "structured_side_effects": [
        {
          "kind": "none",
          "target": "",
          "description": ""
        }
      ],
      "performance_budget": {
        "p95_latency_ms": 1,
        "max_memory_mb": 1,
        "complexity": "O(1)"
      }
    }
  ],
